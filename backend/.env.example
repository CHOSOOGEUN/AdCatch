# FastAPI
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/snap_db

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=snap-images

# Naver SENS (SMS)
NAVER_SENS_SERVICE_ID=your-service-id
NAVER_SENS_ACCESS_KEY=your-access-key
NAVER_SENS_SECRET_KEY=your-secret-key
NAVER_SENS_PHONE_NUMBER=0212345678

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Model
MODEL_YOLO_PATH=models/yolov8n.pt
MODEL_CLASSIFIER_PATH=models/efficientnet_b0.pth
OCR_LANGUAGES=ko,en

# Admin Email
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:8081"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
